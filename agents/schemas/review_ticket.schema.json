{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://colvin-content-os.vercel.app/schemas/review_ticket.schema.json",
  "title": "ReviewTicket",
  "description": "Human review queue item. All content, outreach, and system changes requiring Alfred's approval.",
  "type": "object",
  "required": ["id", "type", "lane", "subject", "draft", "compliance_flags", "katrina_required", "status", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "enum": [
        "outreach",
        "content",
        "remotion_video",
        "funnel",
        "email_sequence",
        "system_change",
        "lead_export",
        "render_approval"
      ]
    },
    "lane": {
      "type": "string",
      "enum": [
        "colvin_enterprises",
        "indiana_backflow_directory",
        "music_theory_secrets",
        "piano_app",
        "youtube_music_education",
        "first_keys_indy",
        "funding_ready_indiana",
        "girls_got_game",
        "glory_engine_yahweh_comics",
        "system"
      ]
    },
    "priority_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 10,
      "description": "Higher = review sooner. P1 incidents auto-set to 10."
    },
    "subject": {
      "type": "string",
      "maxLength": 500,
      "description": "One-line summary of what needs review"
    },
    "draft": {
      "type": "string",
      "description": "The full content/message/change needing review. May be JSON string for video blueprints."
    },
    "context": {
      "type": ["string", "null"],
      "maxLength": 3000,
      "description": "Why this was generated, what campaign it supports, relevant lead research, etc."
    },
    "compliance_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flag_type", "description", "severity"],
        "properties": {
          "flag_type": { "type": "string" },
          "description": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "block"]
          }
        }
      }
    },
    "katrina_required": {
      "type": "boolean",
      "description": "If true, Alfred must personally review. Cannot delegate."
    },
    "auto_approve_eligible": {
      "type": "boolean",
      "default": false,
      "description": "Only true if explicitly low-risk and rule-based. Default false."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_review", "approved", "rejected", "revision_requested", "expired", "escalated"]
    },
    "alfred_decision": {
      "type": ["string", "null"],
      "enum": ["approve", "reject", "request_revision", "escalate", null]
    },
    "alfred_feedback": {
      "type": ["string", "null"],
      "maxLength": 3000
    },
    "decided_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "If not reviewed by this time, escalate or block"
    },
    "related_lead_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "related_content_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "related_video_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "run_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
