{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://colvin-content-os.vercel.app/schemas/content.schema.json",
  "title": "ContentItem",
  "description": "Content draft schema for all platform content generated by Gabriel and marketing agents.",
  "type": "object",
  "required": ["id", "lane", "platform", "content_type", "draft", "review_required", "status", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "lane": {
      "type": "string",
      "enum": [
        "colvin_enterprises",
        "indiana_backflow_directory",
        "music_theory_secrets",
        "piano_app",
        "youtube_music_education",
        "first_keys_indy",
        "funding_ready_indiana",
        "girls_got_game",
        "glory_engine_yahweh_comics"
      ]
    },
    "platform": {
      "type": "string",
      "enum": [
        "tiktok",
        "instagram",
        "facebook",
        "linkedin",
        "youtube",
        "youtube_shorts",
        "email",
        "sms",
        "website",
        "remotion_video",
        "multi_platform"
      ]
    },
    "content_type": {
      "type": "string",
      "enum": [
        "short_form_video_script",
        "long_form_video_script",
        "social_post",
        "carousel_copy",
        "email_subject_line",
        "email_body",
        "blog_post",
        "landing_page_copy",
        "caption",
        "hashtag_set",
        "ad_copy",
        "story_script",
        "reel_script",
        "youtube_shorts_script",
        "remotion_video_brief",
        "lead_magnet_copy",
        "cta_copy"
      ]
    },
    "title": {
      "type": ["string", "null"],
      "maxLength": 300,
      "description": "Internal title for this content piece"
    },
    "draft": {
      "type": "string",
      "minLength": 1,
      "description": "The actual content text or JSON object (for video briefs)"
    },
    "character_count": {
      "type": ["integer", "null"],
      "minimum": 0,
      "description": "Character count of the draft"
    },
    "word_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "hashtags": {
      "type": ["array", "null"],
      "items": {
        "type": "string",
        "pattern": "^#[A-Za-z0-9_]+$"
      },
      "maxItems": 30,
      "description": "Hashtags for social posts"
    },
    "compliance_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flag_type", "description", "severity"],
        "properties": {
          "flag_type": {
            "type": "string",
            "enum": ["hud_respa", "can_spam", "gdpr", "youth_safety", "ftc_disclosure", "financial_claim", "legal_claim", "unverified_statistic", "trademark_risk"]
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "block"]
          }
        }
      },
      "description": "Compliance issues detected. Any 'block' severity prevents publishing."
    },
    "review_required": {
      "type": "boolean",
      "description": "Always true. No content is auto-published."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "approved",
        "rejected",
        "revision_requested",
        "scheduled",
        "published",
        "archived"
      ]
    },
    "alfred_feedback": {
      "type": ["string", "null"],
      "maxLength": 2000,
      "description": "Alfred's notes when approving, rejecting, or requesting revision"
    },
    "campaign_id": {
      "type": ["string", "null"],
      "description": "Links this content to a campaign"
    },
    "run_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "trace_id": {
      "type": ["string", "null"]
    },
    "idempotency_key": {
      "type": ["string", "null"],
      "description": "Idempotency key: {lane}_{platform}_{content_type}_{date}"
    },
    "source_brief": {
      "type": ["string", "null"],
      "maxLength": 1000,
      "description": "The creative brief or prompt that generated this content"
    },
    "scheduled_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "If scheduled, when this content should publish"
    },
    "published_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
