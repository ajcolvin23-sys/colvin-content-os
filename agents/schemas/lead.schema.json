{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://colvin-content-os.vercel.app/schemas/lead.schema.json",
  "title": "Lead",
  "description": "Structured lead record for Colvin Content OS. All leads must pass schema validation before insert.",
  "type": "object",
  "required": ["id", "name", "lane", "source", "status", "provenance", "run_id", "trace_id", "idempotency_key", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4 primary key"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Full name of the lead contact"
    },
    "company": {
      "type": ["string", "null"],
      "maxLength": 300,
      "description": "Company or organization name"
    },
    "title": {
      "type": ["string", "null"],
      "maxLength": 200,
      "description": "Job title or role"
    },
    "linkedin_url": {
      "type": ["string", "null"],
      "format": "uri",
      "pattern": "^https://www\\.linkedin\\.com/",
      "description": "LinkedIn profile URL. Must be public profile."
    },
    "email": {
      "type": ["string", "null"],
      "format": "email",
      "description": "Email address. Never invented — must come from public source."
    },
    "phone": {
      "type": ["string", "null"],
      "pattern": "^[+]?[0-9\\s\\-().]{7,20}$",
      "description": "Phone number if publicly available"
    },
    "city": {
      "type": ["string", "null"],
      "maxLength": 100
    },
    "state": {
      "type": ["string", "null"],
      "maxLength": 50
    },
    "lane": {
      "type": "string",
      "enum": [
        "colvin_enterprises",
        "indiana_backflow_directory",
        "music_theory_secrets",
        "piano_app",
        "youtube_music_education",
        "first_keys_indy",
        "funding_ready_indiana",
        "girls_got_game",
        "glory_engine_yahweh_comics"
      ],
      "description": "Which of Alfred's 9 business lanes this lead belongs to"
    },
    "fit_reason": {
      "type": ["string", "null"],
      "maxLength": 500,
      "description": "Short explanation of why this lead fits the lane"
    },
    "qualification_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10,
      "description": "Lead quality score 0-10. See LEAD_SCORING_RULES.md for formula."
    },
    "source": {
      "type": "string",
      "maxLength": 500,
      "description": "Human-readable description of lead source (e.g. 'Indiana plumber license database', 'LinkedIn search')"
    },
    "status": {
      "type": "string",
      "enum": [
        "raw",
        "enriched",
        "scored",
        "in_outreach_queue",
        "draft_sent_for_approval",
        "approved",
        "contacted",
        "replied",
        "converted",
        "archived",
        "do_not_contact"
      ],
      "description": "Current stage in the lead lifecycle"
    },
    "outreach_angle": {
      "type": ["string", "null"],
      "maxLength": 1000,
      "description": "Suggested personalized outreach angle based on research"
    },
    "provenance": {
      "type": "object",
      "required": ["source_url", "scraped_at", "extractor_version", "confidence"],
      "additionalProperties": false,
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "The URL where this lead was found"
        },
        "scraped_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when data was collected"
        },
        "extractor_version": {
          "type": "string",
          "description": "Version of the extractor/agent that found this lead"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in data accuracy 0-1"
        },
        "robots_txt_checked": {
          "type": "boolean",
          "description": "Whether robots.txt was verified before scraping"
        },
        "is_public_data": {
          "type": "boolean",
          "description": "Whether this data comes from a verified public source"
        }
      }
    },
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "The workflow run that created this lead"
    },
    "trace_id": {
      "type": "string",
      "description": "Stage-level trace identifier for observability"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[a-z_]+_lead_[a-z0-9_]+_[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Idempotency key in format: {lane}_lead_{identifier}_{date}. Prevents duplicate inserts.",
      "examples": ["indiana_backflow_directory_lead_mike_smith_plumbing_2025-01-15"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Overall data confidence for this record"
    },
    "contact_window_expires_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Date after which this lead can be re-contacted (30-day window from last contact)"
    },
    "last_contacted_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp of most recent outreach"
    },
    "notes": {
      "type": ["string", "null"],
      "maxLength": 2000
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
