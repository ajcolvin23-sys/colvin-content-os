{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://colvin-content-os.vercel.app/schemas/remotion_video.schema.json",
  "title": "RemotionVideoBlueprint",
  "description": "Full JSON blueprint for a Remotion video. Generated by REMOTION_VIDEO_AGENT, validated before render trigger.",
  "type": "object",
  "required": [
    "video_id", "campaign", "platform", "duration_seconds", "format",
    "audience", "goal", "hook", "voiceover_script", "scenes",
    "music_direction", "thumbnail_concept", "cta", "claims_check",
    "approval_required", "render_status"
  ],
  "additionalProperties": false,
  "properties": {
    "video_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this video blueprint"
    },
    "campaign": {
      "type": "string",
      "maxLength": 200,
      "description": "Campaign name this video belongs to"
    },
    "lane": {
      "type": "string",
      "enum": [
        "colvin_enterprises",
        "indiana_backflow_directory",
        "music_theory_secrets",
        "piano_app",
        "youtube_music_education",
        "first_keys_indy",
        "funding_ready_indiana",
        "girls_got_game",
        "glory_engine_yahweh_comics"
      ]
    },
    "platform": {
      "type": "string",
      "enum": [
        "tiktok",
        "youtube_shorts",
        "instagram_reels",
        "facebook_reels",
        "linkedin_video"
      ]
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 5,
      "maximum": 600,
      "description": "Total video duration in seconds"
    },
    "format": {
      "type": "string",
      "enum": ["9:16", "1:1", "16:9"],
      "description": "Aspect ratio. 9:16 for TikTok/Reels/Shorts, 16:9 for YouTube, 1:1 for square social."
    },
    "audience": {
      "type": "string",
      "maxLength": 500,
      "description": "Target audience description for this video"
    },
    "goal": {
      "type": "string",
      "enum": [
        "awareness",
        "lead_generation",
        "conversion",
        "education",
        "community_building",
        "authority_building",
        "retargeting"
      ]
    },
    "hook": {
      "type": "string",
      "maxLength": 300,
      "description": "Opening hook text/concept. Must capture attention in first 3 seconds."
    },
    "voiceover_script": {
      "type": "string",
      "description": "Full voiceover script. Written for spoken delivery."
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "scene_number", "duration_seconds", "visual_description",
          "on_screen_text", "caption_text"
        ],
        "additionalProperties": false,
        "properties": {
          "scene_number": {
            "type": "integer",
            "minimum": 1
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0.5,
            "maximum": 120
          },
          "visual_description": {
            "type": "string",
            "maxLength": 1000,
            "description": "What the viewer sees. Describe visuals, colors, layout, motion."
          },
          "component": {
            "type": "string",
            "enum": [
              "HeroHookScene",
              "ProblemAgitationScene",
              "ProofPointScene",
              "OfferRevealScene",
              "StepByStepScene",
              "TestimonialStyleScene",
              "CTAEndCard",
              "ImageSlideshowScene",
              "DataCardScene",
              "LogoIntro",
              "LowerThird",
              "AnimatedText"
            ],
            "description": "Remotion React component to use for this scene"
          },
          "on_screen_text": {
            "type": ["string", "null"],
            "maxLength": 500,
            "description": "Text displayed on screen during this scene"
          },
          "caption_text": {
            "type": ["string", "null"],
            "maxLength": 500,
            "description": "Subtitle/caption text for this scene"
          },
          "motion_direction": {
            "type": ["string", "null"],
            "enum": ["fade_in", "slide_left", "slide_right", "slide_up", "slide_down", "zoom_in", "zoom_out", "static", null],
            "description": "Primary motion animation for this scene"
          },
          "transition": {
            "type": ["string", "null"],
            "enum": ["cut", "fade", "slide", "wipe", "zoom", null],
            "description": "Transition to next scene"
          },
          "asset_requirements": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["asset_type", "description"],
              "properties": {
                "asset_type": {
                  "type": "string",
                  "enum": ["image", "icon", "font", "music", "b_roll_description", "color_palette"]
                },
                "description": {
                  "type": "string"
                },
                "source": {
                  "type": ["string", "null"],
                  "description": "Where to get this asset (e.g. 'Unsplash free license', 'Alfred's brand kit')"
                },
                "license": {
                  "type": ["string", "null"],
                  "enum": ["free", "cc0", "cc_by", "commercial_ok", "alfred_owned", null]
                }
              }
            }
          },
          "voiceover_segment": {
            "type": ["string", "null"],
            "description": "Portion of voiceover script for this scene"
          }
        }
      }
    },
    "music_direction": {
      "type": "string",
      "maxLength": 500,
      "description": "Music/audio direction. Mood, tempo, genre. Must specify free/licensed source."
    },
    "thumbnail_concept": {
      "type": "string",
      "maxLength": 500,
      "description": "Description of thumbnail image concept"
    },
    "cta": {
      "type": "string",
      "maxLength": 300,
      "description": "Call to action text and instruction"
    },
    "cta_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL for the CTA if applicable"
    },
    "claims_check": {
      "type": "object",
      "required": ["risk_level", "issues"],
      "additionalProperties": false,
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "low = no issues, medium = review recommended, high = block until reviewed"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of specific compliance or accuracy issues found"
        },
        "first_keys_indy_hud_check": {
          "type": ["boolean", "null"],
          "description": "If lane is first_keys_indy, was HUD/RESPA compliance verified?"
        }
      }
    },
    "approval_required": {
      "type": "boolean",
      "description": "Always true. Remotion renders never auto-trigger without Alfred's approval.",
      "enum": [true]
    },
    "render_status": {
      "type": "string",
      "enum": ["draft", "approved", "rendering", "rendered", "failed"],
      "description": "Current render pipeline status"
    },
    "template_used": {
      "type": ["string", "null"],
      "description": "Name of template from REMOTION_TEMPLATE_LIBRARY.md if applicable"
    },
    "run_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "trace_id": {
      "type": ["string", "null"]
    },
    "idempotency_key": {
      "type": ["string", "null"],
      "description": "Format: {lane}_video_{campaign_slug}_{date}"
    },
    "render_output_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "URL of rendered video file after successful render"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "rendered_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  }
}
