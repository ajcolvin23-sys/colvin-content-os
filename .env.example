NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Reasoning Core ────────────────────────────────────────────────────
# Claude Opus is the primary reasoning model for Gabriel, Solomon, Genius,
# and the Hermes orchestrator. OpenAI is reserved for bulk dedup/categorization
# only. See automation-os/config/model-routing.json for per-task routing.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

CRON_SECRET=

# Canva Connect API. Keep all values server-side except the public app URL.
# Canva requires MFA before creating a developer integration.
CANVA_ENABLED=false
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://localhost:3000/api/canva/oauth/callback
CANVA_REFRESH_TOKEN=
CANVA_DEFAULT_DESIGN_ID=

# Optional creative providers.
ADOBE_FIREFLY_ENABLED=false
ADOBE_FIREFLY_CLIENT_ID=
ADOBE_FIREFLY_CLIENT_SECRET=
